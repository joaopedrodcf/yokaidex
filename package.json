        "@nuxt/ui": "4.5.1",
        "@nuxtjs/seo": "3.4.0",
        "@vueuse/core": "14.2.1",
        "nuxt": "4.4.2",
        "tailwindcss": "4.2.1",
        "vue": "3.5.30",
        "vue-router": "5.0.3"
    },
    "devDependencies": {
        "@iconify-json/lucide": "1.2.97",
        "oxfmt": "0.40.0",
        "oxlint": "1.55.0",
        "typescript": "5.9.3",
        "vite": "8.0.0",
        "vitest": "4.1.0",
        "vue-tsc": "3.2.5"
    },
    "engines": {
        "node": "22.21.1"
