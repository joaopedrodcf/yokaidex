        "preview": "nuxt preview",
        "test": "vitest run",
        "typecheck": "vue-tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@nuxt/a11y": "1.0.0-alpha.1",
        "@nuxt/hints": "1.1.3",
        "@nuxt/image": "2.0.0",
