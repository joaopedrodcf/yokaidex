        "@nuxt/ui": "4.9.0",
        "@nuxtjs/seo": "5.3.2",
        "@nuxtjs/sitemap": "8.2.2",
        "@vueuse/core": "14.3.0",
        "nuxt": "4.4.8",
        "tailwindcss": "4.3.2",
        "vue": "3.5.39",
        "vue-router": "5.1.0"
    },
    "devDependencies": {
        "@iconify-json/lucide": "1.2.116",
        "@vite-pwa/nuxt": "1.1.1",
        "oxfmt": "0.57.0",
        "oxlint": "1.72.0",
        "typescript": "6.0.3",
        "vite": "8.1.3",
        "vitest": "4.1.9",
        "vue-tsc": "3.3.6"
