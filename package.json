    "description": "Yokaidex on Nuxt with Yo-kai Watch data, SEO, analytics, and static prerendering.",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "check": "oxlint . && oxfmt . --check",
        "check:fix": "oxlint . --fix && oxfmt .",
